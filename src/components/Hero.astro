<section class="hero reveal">
  <div class="container">
    <div class="hero-content">
      <h1>
        Tu web lista en <span class="highlight typewriter-text" id="heroTyping">5 días</span><br>
        Sin vueltas.
      </h1>
      <p>
        Sin agencia, sin vendedores. Hablás directo conmigo, te paso avances
        cada 2 días y pagás solo cuando esté listo. Plazos reales, cero sorpresas.
      </p>
      <div class="hero-buttons">
        <a href="#contactame" class="btn btn-primary fade-in-delay-1 fade-in">Quiero mi web</a>
        <a href="#plantillas" class="btn btn-outline fade-in-delay-2 fade-in">Ver plantillas</a>
      </div>
    </div>
  </div>
</section>

<script>
  const words = ["resultados", "clientes", "ventas"];
  const el = document.getElementById('heroTyping');
  let wordIndex = 0;
  let charIndex = 0;
  let isDeleting = false;
  const typeSpeed = 80;
  const deleteSpeed = 40;
  const pauseBetween = 2000;

  function type() {
    const current = words[wordIndex];

    if (!isDeleting) {
      charIndex++;
      el.textContent = current.substring(0, charIndex);

      if (charIndex === current.length) {
        isDeleting = true;
        setTimeout(type, pauseBetween);
        return;
      }
    } else {
      charIndex--;
      el.textContent = current.substring(0, charIndex);

      if (charIndex === 0) {
        isDeleting = false;
        wordIndex = (wordIndex + 1) % words.length;
        setTimeout(type, 300);
        return;
      }
    }

    setTimeout(type, isDeleting ? deleteSpeed : typeSpeed);
  }

  setTimeout(type, 2000);
</script>