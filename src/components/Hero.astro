<section class="hero reveal">
  <div class="container">
    <div class="hero-content">
      <h1>
        Tu web lista en <span class="highlight typewriter-text" id="heroTyping">5 días<span class="typewriter-cursor">|</span></span>.<br>
        Sin vueltas.
      </h1>
      <p>
        Sin agencia, sin vendedores. Hablás directo conmigo, te paso avances
        cada 2 días y pagás solo cuando esté listo. Plazos reales, cero sorpresas.
      </p>
      <div class="hero-buttons">
        <a href="#contactame" class="btn btn-primary fade-in-delay-1 fade-in">Quiero mi web</a>
        <a href="#plantillas" class="btn btn-outline fade-in-delay-2 fade-in">Ver plantillas</a>
      </div>
    </div>
  </div>
</section>

<script>
  const words = ["5 días", "resultados", "clientes", "ventas"];
  const el = document.getElementById('heroTyping');
  let index = 0;

  setInterval(() => {
    index = (index + 1) % words.length;
    el.style.opacity = '0';
    el.style.transform = 'translateY(6px)';
    setTimeout(() => {
      el.innerHTML = words[index] + '<span class="typewriter-cursor">|</span>';
      el.style.opacity = '1';
      el.style.transform = 'translateY(0)';
    }, 250);
  }, 3000);
</script>