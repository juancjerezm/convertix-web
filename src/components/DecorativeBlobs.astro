<!-- Decorative background blobs — adds depth without distracting -->
<div class="bg-blobs" aria-hidden="true">
  <div class="bg-blob bg-blob--1"></div>
  <div class="bg-blob bg-blob--2"></div>
  <div class="bg-blob bg-blob--3"></div>
</div>

<style is:global>
  .bg-blobs {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .bg-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(130px);
    opacity: 0.07;
  }

  .bg-blob--1 {
    width: 700px;
    height: 700px;
    background: var(--accent-purple);
    top: -200px;
    right: -150px;
  }

  .bg-blob--2 {
    width: 500px;
    height: 500px;
    background: var(--accent-blue);
    bottom: 10%;
    left: -100px;
  }

  .bg-blob--3 {
    width: 600px;
    height: 600px;
    background: linear-gradient(135deg, var(--accent-purple), var(--accent-blue));
    top: 50%;
    right: -200px;
  }

  @media (max-width: 768px) {
    .bg-blob {
      filter: blur(80px);
      opacity: 0.05;
    }
    .bg-blob--1 {
      width: 400px;
      height: 400px;
      top: -100px;
      right: -100px;
    }
    .bg-blob--2 {
      width: 300px;
      height: 300px;
      bottom: 5%;
      left: -80px;
    }
    .bg-blob--3 {
      width: 350px;
      height: 350px;
      top: 40%;
      right: -120px;
    }
  }
</style>

<script>
  import anime from 'animejs/lib/anime.es.js';

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!prefersReduced) {
    const blobDefs = [
      {
        el: document.querySelector('.bg-blob--1'),
        values: [
          '50%',
          '40% 60% 55% 45%',
          '30% 70% 25% 75%',
          '55% 45% 65% 35%',
          '50%',
        ],
        duration: 20000,
      },
      {
        el: document.querySelector('.bg-blob--2'),
        values: [
          '50%',
          '60% 40% 45% 55%',
          '70% 30% 75% 25%',
          '45% 55% 35% 65%',
          '50%',
        ],
        duration: 22000,
      },
      {
        el: document.querySelector('.bg-blob--3'),
        values: [
          '50%',
          '35% 65% 40% 60%',
          '65% 35% 60% 40%',
          '40% 60% 30% 70%',
          '50%',
        ],
        duration: 20000,
      },
    ];

    blobDefs.forEach((b, idx) => {
      if (!b.el) return;
      anime({
        targets: b.el,
        borderRadius: b.values,
        duration: b.duration,
        delay: idx * 3000,
        loop: true,
        direction: 'alternate',
        easing: 'easeInOutSine',
      });
    });
  }
</script>
