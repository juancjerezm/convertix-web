<!-- Decorative background blobs — adds depth without distracting -->
<div class="bg-blobs" aria-hidden="true">
  <div class="bg-blob bg-blob--1"></div>
  <div class="bg-blob bg-blob--2"></div>
  <div class="bg-blob bg-blob--3"></div>
</div>

<style is:global>
  .bg-blobs {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .bg-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(130px);
    opacity: 0.07;
  }

  .bg-blob--1 {
    width: 700px;
    height: 700px;
    background: var(--accent-purple);
    top: -200px;
    right: -150px;
    animation: floatBlob 20s ease-in-out infinite;
  }

  .bg-blob--2 {
    width: 500px;
    height: 500px;
    background: var(--accent-blue);
    bottom: 10%;
    left: -100px;
    animation: floatBlob 25s ease-in-out infinite reverse;
  }

  .bg-blob--3 {
    width: 600px;
    height: 600px;
    background: linear-gradient(135deg, var(--accent-purple), var(--accent-blue));
    top: 50%;
    right: -200px;
    animation: floatBlob 22s ease-in-out infinite;
    animation-delay: -10s;
  }

  @keyframes floatBlob {
    0%, 100% {
      transform: translate(0, 0) scale(1);
    }
    33% {
      transform: translate(30px, -40px) scale(1.1);
    }
    66% {
      transform: translate(-20px, 20px) scale(0.95);
    }
  }

  @media (max-width: 768px) {
    .bg-blob {
      filter: blur(80px);
      opacity: 0.05;
    }
    .bg-blob--1 {
      width: 400px;
      height: 400px;
      top: -100px;
      right: -100px;
    }
    .bg-blob--2 {
      width: 300px;
      height: 300px;
      bottom: 5%;
      left: -80px;
    }
    .bg-blob--3 {
      width: 350px;
      height: 350px;
      top: 40%;
      right: -120px;
    }
  }
</style>
