---
import templates from '../data/templates.json';
---

<section class="landings-express reveal" id="plantillas">
  <div class="container">
    <p class="section-label">Landings Express</p>
    <h2 class="section-title">Tu web, lista en <span class="highlight">días</span></h2>
    <p class="section-subtitle">
      Contáctame y escoge la plantilla que se adapta a tu negocio. Rápido,
      profesional y sin complicaciones.
    </p>

    <div class="templates-grid">
      {
        templates.map((template) => (
          <article class="template-card">
            <div class="template-image">
              <img src={template.image} alt={template.name} class="template-preview" loading="lazy" />
            </div>
            <div class="template-price">{template.price}</div>
            <h3 class="template-name">{template.name}</h3>
            <p class="template-description">{template.description}</p>
            <div class="template-actions">
              <a
                href={`https://wa.me/573152498547?text=${encodeURIComponent(`¡Hola! Quiero la plantilla ${template.name} para mi negocio.`)}`}
                class="btn btn-primary template-cta"
                target="_blank"
                rel="noopener"
              >
                Quiero esta &rarr;
              </a>
              <a href={template.demoUrl} class="btn btn-outline template-demo-btn">
                Ver demo &rarr;
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .landings-express {
    text-align: center;
    background: var(--bg-secondary);
  }

  .landings-express .section-subtitle {
    margin: 0 auto 64px;
  }

  .landings-express .highlight {
    background: var(--gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .templates-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  .template-card {
    background: var(--bg-primary);
    border: 1px solid var(--border);
    border-radius: calc(var(--radius) + 4px);
    padding: 40px 32px;
    text-align: left;
    transition: all var(--transition);
    position: relative;
    overflow: hidden;
  }

  .template-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--gradient);
    opacity: 0;
    transition: opacity var(--transition);
  }

  .template-card:hover {
    border-color: rgba(255, 255, 255, 0.12);
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
  }

  .template-card:hover::before {
    opacity: 1;
  }

  .template-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 10px;
    overflow: hidden;
    margin-bottom: 16px;
    background: var(--bg-primary);
    border: 1px solid var(--border);
  }

  .template-preview {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .template-price {
    display: inline-block;
    background: var(--gradient);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 4px 12px;
    border-radius: 20px;
    margin-bottom: 16px;
    letter-spacing: 0.5px;
  }

  .template-name {
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 12px;
  }

  .template-description {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.7;
    margin-bottom: 24px;
  }

  .template-cta {
    font-size: 0.85rem;
    padding: 10px 24px;
  }

  .template-actions {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .template-demo-btn {
    font-size: 0.85rem;
    padding: 10px 24px;
    text-align: center;
    justify-content: center;
  }

  @media (max-width: 768px) {
    .templates-grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }
  }
</style>
