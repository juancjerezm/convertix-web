<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dr. Ricardo Martínez — Abogado Corporativo</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Lora:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      /* ── Reset ── */
      *,
      *::before,
      *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      html {
        scroll-behavior: smooth;
      }
      body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        color: #2c3e50;
        background: #ffffff;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }
      img {
        display: block;
        max-width: 100%;
      }
      a {
        text-decoration: none;
        color: inherit;
      }

      /* ── Typography ── */
      h1, h2, h3, h4, h5, h6 {
        font-family: 'Lora', Georgia, serif;
        font-weight: 700;
        line-height: 1.25;
        color: #1e3a5f;
      }

      .container {
        max-width: 1120px;
        margin: 0 auto;
        padding: 0 24px;
      }

      .section {
        padding: 80px 0;
      }
      .section-title {
        font-size: 2rem;
        text-align: center;
        margin-bottom: 16px;
        position: relative;
      }
      .section-title::after {
        content: '';
        display: block;
        width: 60px;
        height: 3px;
        background: #c9a84c;
        margin: 12px auto 0;
        border-radius: 2px;
      }
      .section-subtitle {
        text-align: center;
        color: #5a6a7a;
        font-size: 1.05rem;
        max-width: 560px;
        margin: 0 auto 48px;
      }

      /* ── Volver link ── */
      .volver-link {
        position: absolute;
        top: 16px;
        left: 16px;
        z-index: 10;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 16px;
        background: rgba(44, 62, 80, 0.7);
        color: #fff;
        font-size: 0.875rem;
        font-weight: 500;
        border-radius: 6px;
        transition: background 0.2s;
        backdrop-filter: blur(4px);
      }
      .volver-link:hover {
        background: rgba(44, 62, 80, 0.9);
      }

      /* ── Top Nav ── */
      .top-nav {
        background: #1e3a5f;
        padding: 0 24px;
      }
      .top-nav .container {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 64px;
      }
      .top-nav .logo {
        font-family: 'Lora', Georgia, serif;
        font-size: 1.25rem;
        font-weight: 700;
        color: #c9a84c;
        letter-spacing: 0.5px;
      }
      .top-nav .logo span {
        color: #fff;
      }
      .top-nav ul {
        display: flex;
        list-style: none;
        gap: 32px;
      }
      .top-nav ul a {
        color: rgba(255, 255, 255, 0.85);
        font-size: 0.9rem;
        font-weight: 500;
        transition: color 0.2s;
      }
      .top-nav ul a:hover {
        color: #c9a84c;
      }

      /* ── Hero ── */
      .hero {
        padding: 80px 0 64px;
        background: linear-gradient(135deg, #ffffff 0%, #f4f6f8 100%);
        position: relative;
      }
      .hero .container {
        display: flex;
        align-items: center;
        gap: 60px;
      }
      .hero-photo {
        flex-shrink: 0;
        width: 240px;
        height: 240px;
        border-radius: 16px;
        background: #d0d5dd;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 4rem;
        color: #8b95a1;
        font-weight: 300;
        box-shadow: 0 8px 24px rgba(0,0,0,0.08);
      }
      .hero-content h1 {
        font-size: 2.5rem;
        margin-bottom: 4px;
        color: #1e3a5f;
      }
      .hero-content .title {
        font-size: 1.15rem;
        font-weight: 600;
        color: #c9a84c;
        margin-bottom: 8px;
        letter-spacing: 0.3px;
      }
      .hero-content .creds {
        font-size: 0.95rem;
        color: #5a6a7a;
        margin-bottom: 20px;
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
      }
      .hero-content .creds span {
        display: inline-flex;
        align-items: center;
        gap: 4px;
      }
      .hero-content p {
        font-size: 1.05rem;
        color: #4a5a6a;
        max-width: 520px;
        line-height: 1.7;
      }
      .hero-cta {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin-top: 24px;
        padding: 12px 28px;
        background: #1e3a5f;
        color: #fff;
        font-weight: 600;
        font-size: 0.95rem;
        border-radius: 8px;
        transition: background 0.2s;
      }
      .hero-cta:hover {
        background: #152d4a;
      }

      /* ── Services ── */
      .services {
        background: #ffffff;
      }
      .services-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 32px;
      }
      .service-card {
        background: #f8faff;
        border-radius: 12px;
        padding: 36px 28px;
        text-align: center;
        border: 1px solid #eef2f6;
        transition: transform 0.2s, box-shadow 0.2s;
      }
      .service-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 32px rgba(30, 58, 95, 0.08);
      }
      .service-card .icon {
        font-size: 2.5rem;
        margin-bottom: 16px;
      }
      .service-card h3 {
        font-size: 1.2rem;
        margin-bottom: 10px;
        color: #1e3a5f;
      }
      .service-card p {
        font-size: 0.92rem;
        color: #5a6a7a;
        line-height: 1.65;
      }

      /* ── About ── */
      .about {
        background: #f4f6f8;
      }
      .about-layout {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 48px;
        align-items: start;
      }
      .about-layout h2 {
        font-size: 1.8rem;
        margin-bottom: 20px;
      }
      .about-layout p {
        font-size: 1rem;
        color: #4a5a6a;
        margin-bottom: 16px;
        line-height: 1.7;
      }
      .about-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 20px;
        background: #1e3a5f;
        color: #fff;
        font-size: 0.85rem;
        border-radius: 8px;
        font-weight: 500;
        margin-top: 8px;
      }
      .about-stats {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
      }
      .stat-card {
        background: #fff;
        border-radius: 12px;
        padding: 24px;
        text-align: center;
        border: 1px solid #eef2f6;
      }
      .stat-card .number {
        font-family: 'Lora', Georgia, serif;
        font-size: 2rem;
        font-weight: 700;
        color: #c9a84c;
      }
      .stat-card .label {
        font-size: 0.85rem;
        color: #5a6a7a;
        margin-top: 4px;
      }

      /* ── Contact ── */
      .contact {
        background: #ffffff;
      }
      .contact-form {
        max-width: 560px;
        margin: 0 auto;
      }
      .form-group {
        margin-bottom: 20px;
      }
      .form-group label {
        display: block;
        font-size: 0.9rem;
        font-weight: 600;
        color: #1e3a5f;
        margin-bottom: 6px;
      }
      .form-group input,
      .form-group textarea {
        width: 100%;
        padding: 12px 16px;
        border: 1px solid #dde3e9;
        border-radius: 8px;
        font-family: 'Inter', sans-serif;
        font-size: 0.95rem;
        color: #2c3e50;
        background: #fafbfc;
        transition: border-color 0.2s;
      }
      .form-group input:focus,
      .form-group textarea:focus {
        outline: none;
        border-color: #c9a84c;
        background: #fff;
      }
      .form-group textarea {
        resize: vertical;
        min-height: 120px;
      }
      .btn-submit {
        width: 100%;
        padding: 14px;
        background: #1e3a5f;
        color: #fff;
        border: none;
        border-radius: 8px;
        font-family: 'Inter', sans-serif;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s;
      }
      .btn-submit:hover {
        background: #152d4a;
      }
      .contact-info-row {
        display: flex;
        justify-content: center;
        gap: 40px;
        margin-top: 32px;
        color: #5a6a7a;
        font-size: 0.9rem;
      }
      .contact-info-row span {
        display: inline-flex;
        align-items: center;
        gap: 6px;
      }

      /* ── Footer ── */
      .footer {
        background: #1e3a5f;
        color: rgba(255, 255, 255, 0.7);
        text-align: center;
        padding: 32px 24px;
        font-size: 0.85rem;
      }
      .footer a {
        color: #c9a84c;
        transition: color 0.2s;
      }
      .footer a:hover {
        color: #fff;
      }

      /* ── Responsive ── */
      @media (max-width: 768px) {
        .top-nav ul {
          display: none;
        }
        .hero .container {
          flex-direction: column;
          text-align: center;
        }
        .hero-photo {
          width: 160px;
          height: 160px;
          font-size: 3rem;
        }
        .hero-content h1 {
          font-size: 1.8rem;
        }
        .hero-content p {
          max-width: 100%;
        }
        .hero-content .creds {
          justify-content: center;
        }
        .services-grid {
          grid-template-columns: 1fr;
        }
        .about-layout {
          grid-template-columns: 1fr;
        }
        .section {
          padding: 48px 0;
        }
        .contact-info-row {
          flex-direction: column;
          gap: 8px;
          align-items: center;
        }
        .volver-link {
          font-size: 0.8rem;
          padding: 6px 12px;
        }
      }

      @media (max-width: 480px) {
        .hero {
          padding: 64px 0 48px;
        }
        .hero-photo {
          width: 130px;
          height: 130px;
          font-size: 2.2rem;
        }
        .hero-content h1 {
          font-size: 1.5rem;
        }
        .section-title {
          font-size: 1.5rem;
        }
        .about-stats {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <!-- ← Volver a Convertix -->
    <a href="/" class="volver-link">← Volver a Convertix</a>

    <!-- ── Top Nav ── -->
    <nav class="top-nav">
      <div class="container">
        <div class="logo">Dr. Martínez<span> & Asociados</span></div>
        <ul>
          <li><a href="#inicio">Inicio</a></li>
          <li><a href="#servicios">Servicios</a></li>
          <li><a href="#sobre-mi">Sobre mí</a></li>
          <li><a href="#contacto">Contacto</a></li>
        </ul>
      </div>
    </nav>

    <!-- ── Hero ── -->
    <section class="hero" id="inicio">
      <div class="container">
        <div class="hero-photo" aria-label="Foto de perfil del Dr. Martínez">📷</div>
        <div class="hero-content">
          <h1>Dr. Ricardo Martínez</h1>
          <div class="title">Abogado Corporativo</div>
          <div class="creds">
            <span>⭐ 15 años de experiencia</span>
            <span>⚖️ Colegio de Abogados de Bogotá</span>
            <span>📜 Especialista en Derecho Comercial</span>
          </div>
          <p>
            Asesoría jurídica integral para empresas. Protejo tu negocio con
            estrategias legales sólidas, ética profesional y un compromiso
            inquebrantable con tus resultados.
          </p>
          <a href="#contacto" class="hero-cta">Agendar consulta →</a>
        </div>
      </div>
    </section>

    <!-- ── Services ── -->
    <section class="section services" id="servicios">
      <div class="container">
        <h2 class="section-title">Áreas de Práctica</h2>
        <p class="section-subtitle">
          Soluciones legales diseñadas para las necesidades reales de tu empresa
        </p>
        <div class="services-grid">
          <div class="service-card">
            <div class="icon">⚖️</div>
            <h3>Derecho Corporativo</h3>
            <p>
              Constitución de sociedades, redacción de contratos comerciales,
              fusiones y adquisiciones, gobierno corporativo y due diligence.
              Más de 80 empresas asesoradas en su estructura legal.
            </p>
          </div>
          <div class="service-card">
            <div class="icon">📋</div>
            <h3>Litigios</h3>
            <p>
              Representación en procesos civiles y comerciales, arbitraje
              nacional e internacional, resolución alternativa de conflictos
              y defensa corporativa ante entidades regulatorias.
            </p>
          </div>
          <div class="service-card">
            <div class="icon">🤝</div>
            <h3>Consultoría</h3>
            <p>
              Asesoría preventiva en cumplimiento normativo, contratos
              internacionales, propiedad intelectual, planeación patrimonial
              y protección de datos personales.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── About ── -->
    <section class="section about" id="sobre-mi">
      <div class="container">
        <div class="about-layout">
          <div>
            <h2>Sobre mí</h2>
            <p>
              Soy abogado de la Universidad de los Andes con una maestría en
              Derecho Corporativo Internacional de la Universidad de Salamanca.
              Inicié mi carrera en una de las firmas más prestigiosas de Bogotá
              y hace 10 años fundé mi propio despacho.
            </p>
            <p>
              Mi enfoque combina el rigor jurídico con una visión estratégica
              de negocio. Creo firmemente que un buen abogado no solo resuelve
              problemas — los previene. Cada cliente recibe atención
              personalizada y soluciones a la medida de su industria.
            </p>
            <div class="about-badge">🏛️ Miembro activo — Colegio de Abogados de Bogotá</div>
          </div>
          <div class="about-stats">
            <div class="stat-card">
              <div class="number">15+</div>
              <div class="label">Años de experiencia</div>
            </div>
            <div class="stat-card">
              <div class="number">200+</div>
              <div class="label">Casos exitosos</div>
            </div>
            <div class="stat-card">
              <div class="number">80+</div>
              <div class="label">Empresas asesoradas</div>
            </div>
            <div class="stat-card">
              <div class="number">★ 4.9</div>
              <div class="label">Calificación promedio</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Contact ── -->
    <section class="section contact" id="contacto">
      <div class="container">
        <h2 class="section-title">Agenda tu Consulta</h2>
        <p class="section-subtitle">
          Déjame tus datos y te contactaré en menos de 24 horas para una
          primera asesoría sin compromiso
        </p>
        <form class="contact-form" onsubmit="return false;">
          <div class="form-group">
            <label for="nombre">Nombre completo</label>
            <input type="text" id="nombre" placeholder="Tu nombre" />
          </div>
          <div class="form-group">
            <label for="email">Correo electrónico</label>
            <input type="email" id="email" placeholder="tu@correo.com" />
          </div>
          <div class="form-group">
            <label for="mensaje">Mensaje</label>
            <textarea id="mensaje" placeholder="Contame en qué puedo ayudarte..."></textarea>
          </div>
          <button type="button" class="btn-submit">Enviar consulta</button>
        </form>
        <div class="contact-info-row">
          <span>📞 +57 300 123 4567</span>
          <span>✉️ rmartinez@martinezabogados.com</span>
          <span>📍 Bogotá, Colombia</span>
        </div>
      </div>
    </section>

    <!-- ── Footer ── -->
    <footer class="footer">
      <div class="container">
        <p>© 2026 Dr. Ricardo Martínez & Asociados. Todos los derechos reservados.</p>
        <p style="margin-top: 8px;"><a href="/">← Volver a Convertix</a></p>
      </div>
    </footer>
  </body>
</html>
