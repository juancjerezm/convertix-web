<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>LUMINA — Tienda de Moda y Decoración</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Montserrat:wght@600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      /* ── Reset ── */
      *,
      *::before,
      *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      html {
        scroll-behavior: smooth;
      }
      body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        color: #1a1a2e;
        background: #ffffff;
        line-height: 1.5;
        -webkit-font-smoothing: antialiased;
      }
      img {
        display: block;
        max-width: 100%;
      }
      a {
        text-decoration: none;
        color: inherit;
      }

      /* ── Typography ── */
      h1, h2, h3, h4, h5, h6 {
        font-family: 'Montserrat', sans-serif;
        font-weight: 800;
        line-height: 1.15;
        color: #1a1a2e;
      }

      .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 24px;
      }

      /* ── Volver link ── */
      .volver-link {
        position: absolute;
        top: 16px;
        left: 16px;
        z-index: 10;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 16px;
        background: rgba(26, 26, 46, 0.7);
        color: #fff;
        font-size: 0.875rem;
        font-weight: 500;
        border-radius: 6px;
        transition: background 0.2s;
        backdrop-filter: blur(4px);
      }
      .volver-link:hover {
        background: rgba(26, 26, 46, 0.9);
      }

      /* ── Top Bar ── */
      .top-bar {
        background: #ff6b6b;
        color: #fff;
        text-align: center;
        padding: 10px 16px;
        font-size: 0.9rem;
        font-weight: 600;
        letter-spacing: 0.3px;
      }

      /* ── Header ── */
      .site-header {
        background: #ffffff;
        border-bottom: 1px solid #eef0f2;
        position: sticky;
        top: 0;
        z-index: 20;
      }
      .site-header .container {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 72px;
      }
      .site-logo {
        font-family: 'Montserrat', sans-serif;
        font-size: 1.6rem;
        font-weight: 900;
        color: #1a1a2e;
        letter-spacing: 2px;
      }
      .site-logo span {
        color: #ff6b6b;
      }
      .site-nav {
        display: flex;
        list-style: none;
        gap: 28px;
      }
      .site-nav a {
        font-size: 0.9rem;
        font-weight: 500;
        color: #4a4a5a;
        transition: color 0.2s;
        position: relative;
        padding-bottom: 4px;
      }
      .site-nav a::after {
        content: '';
        position: absolute;
        bottom: -2px;
        left: 0;
        width: 0;
        height: 2px;
        background: #ff6b6b;
        transition: width 0.2s;
        border-radius: 1px;
      }
      .site-nav a:hover {
        color: #ff6b6b;
      }
      .site-nav a:hover::after {
        width: 100%;
      }
      .header-actions {
        display: flex;
        align-items: center;
        gap: 16px;
      }
      .cart-icon {
        font-size: 1.4rem;
        cursor: default;
        position: relative;
      }
      .cart-icon::after {
        content: '0';
        position: absolute;
        top: -6px;
        right: -8px;
        background: #ff6b6b;
        color: #fff;
        font-size: 0.65rem;
        font-weight: 700;
        width: 18px;
        height: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
      }

      /* ── Hero Banner ── */
      .hero-banner {
        background: linear-gradient(135deg, #ff6b6b 0%, #ee5a5a 50%, #d94f4f 100%);
        color: #fff;
        text-align: center;
        padding: 100px 24px;
        position: relative;
        overflow: hidden;
      }
      .hero-banner::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -30%;
        width: 600px;
        height: 600px;
        background: rgba(255, 255, 255, 0.06);
        border-radius: 50%;
      }
      .hero-banner::after {
        content: '';
        position: absolute;
        bottom: -40%;
        left: -20%;
        width: 500px;
        height: 500px;
        background: rgba(255, 255, 255, 0.04);
        border-radius: 50%;
      }
      .hero-banner h1 {
        font-size: 3.2rem;
        color: #fff;
        margin-bottom: 12px;
        position: relative;
        z-index: 1;
      }
      .hero-banner p {
        font-size: 1.15rem;
        opacity: 0.9;
        margin-bottom: 28px;
        position: relative;
        z-index: 1;
        max-width: 480px;
        margin-left: auto;
        margin-right: auto;
      }
      .hero-banner .btn-cta {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 14px 36px;
        background: #1a1a2e;
        color: #fff;
        font-weight: 700;
        font-size: 0.95rem;
        border-radius: 50px;
        transition: transform 0.2s, box-shadow 0.2s;
        position: relative;
        z-index: 1;
      }
      .hero-banner .btn-cta:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
      }

      /* ── Section common ── */
      .section {
        padding: 72px 0;
      }
      .section-title {
        font-size: 2rem;
        text-align: center;
        margin-bottom: 40px;
        position: relative;
      }
      .section-title::after {
        content: '';
        display: block;
        width: 50px;
        height: 3px;
        background: #ff6b6b;
        margin: 12px auto 0;
        border-radius: 2px;
      }

      /* ── Product Grid ── */
      .products {
        background: #ffffff;
      }
      .product-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 24px;
      }
      .product-card {
        background: #ffffff;
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid #eef0f2;
        transition: transform 0.2s, box-shadow 0.2s;
      }
      .product-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 32px rgba(0, 0, 0, 0.06);
      }
      .product-image {
        width: 100%;
        aspect-ratio: 1 / 1;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.2rem;
        color: rgba(255, 255, 255, 0.6);
        font-weight: 600;
      }
      .product-info {
        padding: 16px;
      }
      .product-info h3 {
        font-family: 'Inter', sans-serif;
        font-size: 0.95rem;
        font-weight: 600;
        color: #1a1a2e;
        margin-bottom: 6px;
        line-height: 1.3;
      }
      .product-price {
        font-size: 1.1rem;
        font-weight: 700;
        color: #ff6b6b;
        margin-bottom: 12px;
      }
      .product-price .old-price {
        font-size: 0.85rem;
        color: #9a9aaa;
        text-decoration: line-through;
        font-weight: 400;
        margin-right: 8px;
      }
      .btn-add {
        width: 100%;
        padding: 10px;
        border: 1px solid #ff6b6b;
        background: transparent;
        color: #ff6b6b;
        border-radius: 8px;
        font-family: 'Inter', sans-serif;
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s, color 0.2s;
      }
      .btn-add:hover {
        background: #ff6b6b;
        color: #fff;
      }

      /* ── Newsletter ── */
      .newsletter {
        background: #f8f9fa;
      }
      .newsletter-box {
        max-width: 540px;
        margin: 0 auto;
        text-align: center;
      }
      .newsletter-box h2 {
        font-size: 1.8rem;
        margin-bottom: 8px;
      }
      .newsletter-box p {
        color: #5a5a6e;
        margin-bottom: 24px;
        font-size: 1rem;
      }
      .newsletter-form {
        display: flex;
        gap: 12px;
      }
      .newsletter-form input {
        flex: 1;
        padding: 14px 18px;
        border: 1px solid #dde3e9;
        border-radius: 8px;
        font-family: 'Inter', sans-serif;
        font-size: 0.95rem;
        color: #1a1a2e;
        background: #fff;
      }
      .newsletter-form input:focus {
        outline: none;
        border-color: #ff6b6b;
      }
      .newsletter-form button {
        padding: 14px 28px;
        background: #ff6b6b;
        color: #fff;
        border: none;
        border-radius: 8px;
        font-family: 'Inter', sans-serif;
        font-size: 0.95rem;
        font-weight: 700;
        cursor: pointer;
        transition: background 0.2s;
        white-space: nowrap;
      }
      .newsletter-form button:hover {
        background: #e55a5a;
      }

      /* ── Footer ── */
      .site-footer {
        background: #1a1a2e;
        color: rgba(255, 255, 255, 0.7);
        padding: 48px 24px 32px;
      }
      .site-footer .container {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1fr;
        gap: 40px;
      }
      .site-footer h4 {
        font-family: 'Montserrat', sans-serif;
        font-size: 1rem;
        color: #fff;
        margin-bottom: 16px;
      }
      .site-footer p,
      .site-footer li {
        font-size: 0.88rem;
        line-height: 1.8;
      }
      .site-footer ul {
        list-style: none;
      }
      .site-footer a {
        color: rgba(255, 255, 255, 0.6);
        transition: color 0.2s;
      }
      .site-footer a:hover {
        color: #ff6b6b;
      }
      .footer-brand .logo-small {
        font-family: 'Montserrat', sans-serif;
        font-size: 1.3rem;
        font-weight: 900;
        color: #fff;
        letter-spacing: 2px;
        margin-bottom: 8px;
      }
      .footer-brand .logo-small span {
        color: #ff6b6b;
      }
      .footer-bottom {
        grid-column: 1 / -1;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        padding-top: 24px;
        margin-top: 8px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.82rem;
        color: rgba(255, 255, 255, 0.5);
      }
      .footer-bottom .volver-footer {
        color: #ff6b6b;
        font-weight: 600;
      }
      .footer-bottom .volver-footer:hover {
        color: #fff;
      }

      /* ── Responsive ── */
      @media (max-width: 992px) {
        .product-grid {
          grid-template-columns: repeat(2, 1fr);
        }
        .site-footer .container {
          grid-template-columns: 1fr 1fr;
        }
      }

      @media (max-width: 768px) {
        .site-nav {
          display: none;
        }
        .hero-banner {
          padding: 72px 24px;
        }
        .hero-banner h1 {
          font-size: 2.2rem;
        }
        .section {
          padding: 48px 0;
        }
        .newsletter-form {
          flex-direction: column;
        }
        .site-footer .container {
          grid-template-columns: 1fr;
          gap: 32px;
        }
        .footer-bottom {
          flex-direction: column;
          gap: 12px;
          text-align: center;
        }
        .volver-link {
          font-size: 0.8rem;
          padding: 6px 12px;
        }
      }

      @media (max-width: 480px) {
        .hero-banner h1 {
          font-size: 1.7rem;
        }
        .section-title {
          font-size: 1.5rem;
        }
        .product-grid {
          grid-template-columns: 1fr;
        }
        .site-header .container {
          height: 60px;
        }
        .site-logo {
          font-size: 1.3rem;
        }
        .top-bar {
          font-size: 0.8rem;
          padding: 8px 12px;
        }
      }
    </style>
  </head>
  <body>
