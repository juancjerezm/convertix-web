---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <section style="min-height: 60vh; display: flex; align-items: center; justify-content: center; text-align: center; padding: 120px 24px;">
    <div>
      <div style="font-size: 3rem; margin-bottom: 20px;">✅</div>
      <h1 style="font-size: 2rem; font-weight: 800; margin-bottom: 12px;">¡Gracias por tu mensaje!</h1>
      <p style="color: var(--text-muted); font-size: 1.1rem; margin-bottom: 32px; max-width: 400px; margin-inline: auto;">
        Te responderé en menos de 24 horas. Mientras tanto, podés seguir explorando.
      </p>
      <a href="/" class="btn btn-primary" style="display: inline-flex;">Volver al inicio</a>
    </div>
  </section>
</BaseLayout>
